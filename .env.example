# Groq API Key (required for LLM)
GROQ_API_KEY=your_groq_api_key_here

# Data paths
DATA_DIR=./data
DOCS_DIR=./data/docs
CHROMA_DB_DIR=./chroma_db
BM25_INDEX_PATH=./data/bm25_index.pkl
BM25_REGISTRY_PATH=./data/bm25_registry.json

# Model configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QUERY_ANALYZER_MODEL=llama-3.1-8b-instant
ANSWER_MODEL=llama-3.3-70b-versatile
ANSWER_MODEL_TEMP=0.7
ANSWER_MODEL_MAX_TOKENS=1024

# Retrieval configuration
VECTOR_RETRIEVAL_TOP_K=20
BM25_RETRIEVAL_TOP_K=20
HYBRID_FUSION_TOP_K=10
BM25_RRF_K=60

# Chunking configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Evaluation
EVAL_BATCH_SIZE=5
USE_RAGAS=true

# Logging
LOG_LEVEL=INFO
